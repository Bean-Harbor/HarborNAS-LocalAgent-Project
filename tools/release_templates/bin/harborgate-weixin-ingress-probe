#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RELEASE_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
ENV_FILE="${HARBOR_ENV_FILE:-/etc/default/harborbeacon-agent-hub}"

if [[ -f "${ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "${ENV_FILE}"
  set +a
fi

export PYTHONPATH="${RELEASE_ROOT}/harborgate/site-packages${PYTHONPATH:+:${PYTHONPATH}}"
cd "${RELEASE_ROOT}"
exec "${HARBORGATE_PYTHON_BIN:-python3}" -m im_agent.weixin_ingress_probe "$@"
