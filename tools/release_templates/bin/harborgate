#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RELEASE_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
HARBORGATE_BIN="${RELEASE_ROOT}/harborgate/bin/harborgate"

if [[ ! -x "${HARBORGATE_BIN}" ]]; then
  echo "HarborGate Rust binary is missing or not executable: ${HARBORGATE_BIN}" >&2
  exit 127
fi

cd "${RELEASE_ROOT}"
exec "${HARBORGATE_BIN}" "$@"
