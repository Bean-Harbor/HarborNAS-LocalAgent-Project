#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RELEASE_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
ENV_FILE="${HARBOR_ENV_FILE:-/etc/default/harborbeacon-agent-hub}"

if [[ -f "${ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "${ENV_FILE}"
  set +a
fi

exec "${HARBOR_VLM_PYTHON:-python3}" \
  "${HARBOR_VLM_SIDECAR_SCRIPT:-${RELEASE_ROOT}/templates/bin/harbor-vlm-sidecar}" \
  "$@"
